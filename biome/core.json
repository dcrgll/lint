{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "extends": ["ultracite/biome/core"],
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!**/node_modules/**",
      "!**/.next/**",
      "!**/.turbo/**",
      "!**/.vercel/**",
      "!**/dist/**",
      "!**/build/**",
      "!**/coverage/**",
      "!**/out/**",
      "!**/storybook-static/**",
      "!**/playwright-report/**",
      "!**/test-results/**",
      "!**/.source/**",
      "!**/.cache/**",
      "!**/.expo/**",
      "!**/.output/**",
      "!**/.wrangler/**",
      "!**/.svelte-kit/**",
      "!**/.nuxt/**",
      "!**/.vite/**",
      "!**/.vinxi/**",
      "!**/dev-dist/**",
      "!**/tmp/**",
      "!**/temp/**"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "tab",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded",
      "trailingCommas": "none",
      "arrowParentheses": "asNeeded",
      "bracketSpacing": true
    }
  },
  "linter": {
    "rules": {
      "a11y": {
        "useKeyWithClickEvents": "error"
      }
    }
  },
  "assist": {
    "actions": {
      "source": {
        "useSortedAttributes": "on",
        "useSortedProperties": "on",
        "useSortedKeys": "on",
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": [
              ":URL:",
              ":BUN:",
              ":NODE:",
              ":PACKAGE:",
              ":PACKAGE_WITH_PROTOCOL:",
              "~/types",
              "~/utils",
              "~/hooks",
              "~/configs",
              "~/constants",
              "~/models",
              "~/services",
              "~/components",
              "~/styles",
              ":BLANK_LINE:",
              ":ALIAS:",
              ":PATH:"
            ]
          }
        }
      }
    }
  }
}
